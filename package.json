{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev:frontend": "pnpm --filter finance-advisor run dev",
    "dev:backend": "pnpm --filter api-server run dev",
    "dev": "npx -y concurrently \"pnpm run dev:frontend\" \"pnpm run dev:backend\"",
    "start": "pnpm run dev"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@swc/core",
      "esbuild",
      "msw",
      "unrs-resolver"
    ]
  }
}
